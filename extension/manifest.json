{
  "manifest_version": 3,
  "name": "Prism Prototype",
  "version": "0.0.1",
  "description": "Signal engine prototype for Prism.",
  "permissions": ["tabs", "idle", "storage"],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html"
  }
}
